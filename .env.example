# AI Provider 基础配置
# 手动指定当前使用的 provider：
# mock | openai | anthropic | custom
# 切真实模型时，改成 openai / anthropic / custom 之一即可。
NOVEL_AI_PROVIDER=mock
NOVEL_AI_MODEL=gpt-4.1-mini

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Custom（OpenAI Chat Completions 兼容协议）
CUSTOM_AI_API_KEY=
CUSTOM_AI_BASE_URL=https://your-custom-ai.example.com
CUSTOM_AI_CHAT_PATH=/v1/chat/completions
CUSTOM_AI_MODELS_PATH=/v1/models
CUSTOM_AI_AUTH_HEADER=Authorization
CUSTOM_AI_AUTH_PREFIX=Bearer
CUSTOM_AI_REQUIRE_API_KEY=false

# 显示与日志截断长度
NOVEL_DISPLAY_RUN_TEXT_PREVIEW_LENGTH=120
NOVEL_DISPLAY_NETWORK_ERROR_PREVIEW_LENGTH=200
NOVEL_DISPLAY_GENERATION_PREVIEW_LENGTH=120
NOVEL_DISPLAY_MOCK_MENTION_SUMMARY_LENGTH=120

# Prompt 控长阈值
NOVEL_CONTEXT_MAX_CHARACTER_ITEMS=8
NOVEL_CONTEXT_MAX_FACTION_ITEMS=6
NOVEL_CONTEXT_MAX_LORE_ITEMS=8
NOVEL_CONTEXT_MAX_RELATION_ITEMS=8
NOVEL_CONTEXT_MAX_CHARACTER_FACTION_ITEMS=8
NOVEL_CONTEXT_MAX_HOOK_ITEMS=8
NOVEL_CONTEXT_MAX_STATE_ITEMS=8

# 人物相关性打分
NOVEL_RELEVANCE_CHARACTER_PROTAGONIST_BONUS=120
NOVEL_RELEVANCE_CHARACTER_ANTAGONIST_BONUS=50
NOVEL_RELEVANCE_CHARACTER_NAME_MATCH_BONUS=100
NOVEL_RELEVANCE_CHARACTER_GOAL_MATCH_BONUS=40
NOVEL_RELEVANCE_CHARACTER_CONFLICT_MATCH_BONUS=35
NOVEL_RELEVANCE_CHARACTER_FACTION_MATCH_BONUS=45
NOVEL_RELEVANCE_CHARACTER_LATEST_STATE_BONUS=20

# 势力相关性打分
NOVEL_RELEVANCE_FACTION_NAME_MATCH_BONUS=110
NOVEL_RELEVANCE_FACTION_GOAL_MATCH_BONUS=35
NOVEL_RELEVANCE_FACTION_STANCE_MATCH_BONUS=15
NOVEL_RELEVANCE_FACTION_CHARACTER_MATCH_BONUS=60
NOVEL_RELEVANCE_FACTION_LATEST_STATE_BONUS=20

# 钩子相关性打分
NOVEL_RELEVANCE_HOOK_DIRECT_LINK_BONUS=140
NOVEL_RELEVANCE_HOOK_TARGET_CHAPTER_BONUS=120
NOVEL_RELEVANCE_HOOK_TITLE_MATCH_BONUS=80
NOVEL_RELEVANCE_HOOK_SUMMARY_MATCH_BONUS=35
NOVEL_RELEVANCE_HOOK_LATEST_ADVANCED_BONUS=25

# 快照排序权重
NOVEL_RELEVANCE_SNAPSHOT_BASE_SCORE=10000
NOVEL_RELEVANCE_HOOK_STATE_RESOLVED_BONUS=10
NOVEL_RELEVANCE_HOOK_STATE_ADVANCED_BONUS=20

# AI 任务调优
NOVEL_AI_DOCTOR_TEST_MAX_OUTPUT_TOKENS=60
NOVEL_AI_DOCTOR_CHAPTER_PLAN_MAX_OUTPUT_TOKENS=600
NOVEL_AI_DOCTOR_DRAFT_WRITE_MAX_OUTPUT_TOKENS=800
NOVEL_AI_DOCTOR_DRAFT_FIX_MAX_OUTPUT_TOKENS=900
NOVEL_AI_CHAPTER_PLAN_TEMPERATURE=0.7
NOVEL_AI_CHAPTER_PLAN_MAX_OUTPUT_TOKENS=1400
NOVEL_AI_DRAFT_FIX_TEMPERATURE=0.6
NOVEL_AI_DRAFT_FIX_MAX_OUTPUT_TOKENS=1800
NOVEL_AI_STATE_EXTRACT_TEMPERATURE=0.2
NOVEL_AI_STATE_EXTRACT_MAX_OUTPUT_TOKENS=1200

# 规则修稿辅助参数
NOVEL_DRAFT_FIX_IMPORTANT_FACTION_LIMIT=2
